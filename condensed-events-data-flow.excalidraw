      "y": 268,
      "width": 310,
      "height": 135,
      "text": "Condensed ModelEvent:\n{\n  \"event\": \"model\",\n  \"input\": [],\n  \"input_refs\": [[0, 3], [5, 7]],\n  \"call\": {\n    \"call_refs\": [[0, 2]],\n    \"call_key\": \"messages\"\n  }\n}",
